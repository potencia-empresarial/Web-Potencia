ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORT=3000

# ─── Pancake CRM (API v1 del POS) ───────────────────────────────
# Los leads del Diagnóstico Web caen en la tabla Contact del shop de Potencia.
# Endpoint: POST https://pos.pages.fm/api/v1/shops/{SHOP_ID}/crm/{TABLA}/records?api_key=KEY
# La API key es la POS de Potencia (misma que PANCAKE_POS_API_KEY__POTENCIA del dashboard SAV).
PANCAKE_ENABLED=true
PANCAKE_API_KEY=pega_aqui_la_api_key_pos_de_potencia
PANCAKE_SHOP_ID=1022053221
PANCAKE_TABLE_NAME=Contact
# PANCAKE_API_URL solo si necesitas sobreescribir la URL construida (normalmente NO definirla)
PANCAKE_TIMEOUT_SEG=5
